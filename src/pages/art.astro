---
import FragmentStream from '../components/FragmentStream.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getFragments } from '../lib/fragments.js';

const fragments = getFragments({ mode: 'art' });
---

<BaseLayout title="Art | r3frag" description="Art fragments from the r3frag archive.">
  <FragmentStream
    fragments={fragments}
    title="Art"
    intro="Images and brief captions kept in the same chronological language as the archive."
  />
</BaseLayout>
