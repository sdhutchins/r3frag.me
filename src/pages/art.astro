---
import FragmentStream from '../components/FragmentStream.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import pages from '../data/pages.json';
import siteData from '../data/site.json';
import { getFragments } from '../lib/fragments.js';

const fragments = getFragments({ mode: 'art' });
---

<BaseLayout
  title={`${pages.art.title} | ${siteData.siteDefaults.title}`}
  description={pages.art.description}
>
  <FragmentStream
    fragments={fragments}
    title={pages.art.title}
    intro={pages.art.intro}
  />
</BaseLayout>
