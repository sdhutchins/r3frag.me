---
import FragmentStream from '../components/FragmentStream.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import pages from '../data/pages.json';
import { getFragments } from '../lib/fragments.js';

const fragments = getFragments();
---

<BaseLayout
  title={pages.index.title}
  description={pages.index.description}
>
  <FragmentStream
    fragments={fragments}
    intro={pages.index.byline}
  />
</BaseLayout>
