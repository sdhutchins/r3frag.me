---
import '../styles/global.css';
import siteData from '../data/site.json';

const {
  title = siteData.siteDefaults.title,
  description = siteData.siteDefaults.description,
} = Astro.props;

const pathname = Astro.url.pathname;
const [brandLink, ...navLinks] = siteData.navigation;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav" aria-label="Primary">
        <div class="site-nav__inner">
          <a
            href={brandLink.href}
            class:list={[
              'site-nav__link',
              'site-nav__brand',
              pathname === brandLink.href && 'is-active',
            ]}
            aria-current={pathname === brandLink.href ? 'page' : undefined}
          >
            {brandLink.label}
          </a>

          <div class="site-nav__links">
            {navLinks.map((link) => (
              <a
                href={link.href}
                class:list={['site-nav__link', pathname === link.href && 'is-active']}
                aria-current={pathname === link.href ? 'page' : undefined}
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>
      </nav>
    </header>

    <main class="site-main">
      <slot />
    </main>
  </body>
</html>
